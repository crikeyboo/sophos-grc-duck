{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Crikeyboo/SOPHOS-GRC-Duck/schemas/product-capability.schema.json",
  "title": "Product Capability",
  "description": "Schema for describing a normalised Sophos product or service capability before mapping it to cybersecurity frameworks.",
  "type": "object",
  "required": [
    "capability_id",
    "capability_status",
    "product",
    "capability_name",
    "capability_statement",
    "capability_domain",
    "evidence",
    "review"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "description": "Unique identifier for the capability.",
      "examples": [
        "CAP-SOPHOS-XDR-TELEMETRY-CORRELATION-001"
      ]
    },
    "capability_status": {
      "type": "string",
      "description": "Lifecycle status of the capability record.",
      "enum": [
        "Draft",
        "AI Suggested",
        "Needs Evidence",
        "Product Owner Review",
        "GRC Review",
        "Approved",
        "Rejected",
        "Retired"
      ]
    },
    "product": {
      "type": "object",
      "required": [
        "product_name"
      ],
      "properties": {
        "product_name": {
          "type": "string",
          "examples": [
            "Sophos XDR",
            "Sophos MDR",
            "Sophos Endpoint",
            "Sophos Firewall"
          ]
        },
        "product_family": {
          "type": "string",
          "examples": [
            "Endpoint",
            "Network",
            "Managed Services",
            "Cloud",
            "Email"
          ]
        },
        "product_module": {
          "type": "string",
          "examples": [
            "Threat Detection",
            "Endpoint Protection",
            "Firewall Policy",
            "Managed Detection and Response"
          ]
        },
        "product_version": {
          "type": "string",
          "description": "Product, service or documentation version where relevant."
        }
      }
    },
    "capability_name": {
      "type": "string",
      "description": "Short name for the capability.",
      "examples": [
        "Security telemetry correlation",
        "Endpoint malware prevention",
        "Network access control"
      ]
    },
    "capability_statement": {
      "type": "string",
      "description": "Normalised statement of what the Sophos product or service capability does."
    },
    "capability_domain": {
      "type": "string",
      "enum": [
        "Identity and Access",
        "Endpoint Protection",
        "Network Security",
        "Email Security",
        "Cloud Security",
        "Data Protection",
        "Logging and Telemetry",
        "Threat Detection",
        "Threat Intelligence",
        "Incident Response",
        "Vulnerability and Exposure Management",
        "Configuration and Hardening",
        "Asset Visibility",
        "Policy Enforcement",
        "Reporting and Assurance",
        "Managed Service Support",
        "Other"
      ]
    },
    "security_outcomes": {
      "type": "array",
      "description": "Plain English security outcomes supported by the capability.",
      "items": {
        "type": "string"
      },
      "examples": [
        [
          "Improves visibility of security events across supported sources",
          "Supports investigation and triage of suspicious activity"
        ]
      ]
    },
    "customer_dependencies": {
      "type": "array",
      "description": "Customer-owned configuration, process, integration or operational dependencies.",
      "items": {
        "type": "string"
      }
    },
    "sophos_dependencies": {
      "type": "array",
      "description": "Sophos-owned service, product or operational dependencies.",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "description": "Evidence items supporting the capability statement.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "evidence_title",
          "evidence_source_type",
          "evidence_location",
          "evidence_quality_level"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "examples": [
              "EV-SOPHOS-XDR-DOC-001"
            ]
          },
          "evidence_title": {
            "type": "string"
          },
          "evidence_source_type": {
            "type": "string",
            "enum": [
              "Public Product Documentation",
              "Internal Product Documentation",
              "Git Repository",
              "Detection Rule or Query",
              "API Specification",
              "Configuration Guide",
              "Architecture Diagram",
              "Service Runbook",
              "Support Knowledge Base",
              "Product Owner Confirmation",
              "GRC Reviewer Confirmation",
              "Customer Implementation Evidence",
              "Sales or Marketing Material",
              "Other"
            ]
          },
          "evidence_location": {
            "type": "string",
            "description": "URL, repository path, document path or citation location."
          },
          "publication_or_update_date": {
            "type": "string",
            "description": "Date of publication or last update, if known."
          },
          "evidence_extract": {
            "type": "string",
            "description": "Short extracted statement supporting the capability."
          },
          "evidence_quality_level": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5,
            "description": "0 = no evidence, 5 = authoritative technical evidence."
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "description": "Known exclusions, caveats or limitations.",
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "required": [
        "created_by",
        "created_date",
        "last_reviewed_by",
        "last_reviewed_date"
      ],
      "properties": {
        "created_by": {
          "type": "string"
        },
        "created_date": {
          "type": "string"
        },
        "last_reviewed_by": {
          "type": "string"
        },
        "last_reviewed_date": {
          "type": "string"
        },
        "review_notes": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": false
}
